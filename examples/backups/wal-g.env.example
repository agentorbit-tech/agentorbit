# wal-g.env.example — WAL-G configuration for AgentOrbit self-host backups.
# Copy to /etc/wal-g.env (root-owned, mode 600) and reference from your
# postgres systemd unit (e.g. EnvironmentFile=-/etc/wal-g.env).
#
# Cross-reference: docs/deployment-guide.md "Backups (Self-host)".

# -----------------------------------------------------------------------------
# Storage destination — required.
# -----------------------------------------------------------------------------
# Format: s3://<bucket>/<prefix>
# Use one prefix per cluster so retention/restore commands don't collide.
WALG_S3_PREFIX=s3://my-bucket/agentorbit/wal-g

# -----------------------------------------------------------------------------
# Bucket credentials — required.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=changeme_access_key
AWS_SECRET_ACCESS_KEY=changeme_secret_key
AWS_REGION=us-east-1

# For S3-compatible providers (MinIO, Backblaze B2, Wasabi, etc.) set
# AWS_ENDPOINT to the provider URL and AWS_S3_FORCE_PATH_STYLE=true.
# AWS_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# AWS_S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Encryption-at-rest — REQUIRED. Do not skip even if the bucket is "private".
# -----------------------------------------------------------------------------
# Long-form fingerprint of a GPG key whose private half lives off-host. WAL-G
# encrypts every WAL segment + base backup with this key before upload.
WALG_GPG_KEY_ID=ABCDEF0123456789ABCDEF0123456789ABCDEF01

# -----------------------------------------------------------------------------
# Compression — optional. lz4 is the default; zstd compresses better but costs
# more CPU on the postgres host.
# -----------------------------------------------------------------------------
WALG_COMPRESSION_METHOD=lz4

# -----------------------------------------------------------------------------
# Tuning — optional, sane defaults shown.
# -----------------------------------------------------------------------------
# Number of parallel WAL upload workers.
WALG_UPLOAD_CONCURRENCY=4
# Number of parallel WAL download workers (used by wal-g wal-fetch).
WALG_DOWNLOAD_CONCURRENCY=4
# Number of parallel disk-read workers during backup-push.
WALG_DISK_RATE_LIMIT=
# WAL upload buffer size in MB. Higher = fewer flushes, more memory.
WALG_UPLOAD_DISK_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Operational guards — optional.
# -----------------------------------------------------------------------------
# Postgres datadir — passed by archive_command via %p, but also used by
# backup-push when invoked manually.
PGDATA=/var/lib/postgresql/data

# ============================================================
# AgentOrbit Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# Database (postgres service)
POSTGRES_DB=agentorbit
POSTGRES_USER=agentorbit
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Processing service
# sslmode=disable is acceptable inside Docker networks.
# For production with external PostgreSQL, use sslmode=require.
# DATABASE_URL is built automatically from POSTGRES_* in docker-compose;
# uncomment + set explicitly only when running against an external PostgreSQL.
# DATABASE_URL=postgres://user:pass@host:5432/agentorbit?sslmode=require
# Generate each of the following with: openssl rand -hex 32
JWT_SECRET=
HMAC_SECRET=
ENCRYPTION_KEY=
INTERNAL_TOKEN=
APP_BASE_URL=http://localhost:8081
PROCESSING_PORT=8081
PORT=8081
DEPLOYMENT_MODE=self_host
JWT_TTL_DAYS=30
# REQUIRED for cross-origin access. Comma-separated list of frontend URLs.
# For Docker self-host: http://localhost:8081
# For custom domain: https://your-domain.com
# If empty, CORS headers are not sent (browser blocks cross-origin requests).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# Skip email verification (set to 1 to auto-verify users on registration)
# Recommended for self-host. Comment out or remove for cloud deployment with SMTP.
SKIP_EMAIL_VERIFICATION=1

# SMTP (optional — omit to use copyable links instead of email)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=
# SMTP_FROM=AgentOrbit <noreply@example.com>

# Data retention (optional — 0 or omit to keep data forever)
# DATA_RETENTION_DAYS=90

# LLM for narratives and clustering (optional — Pro/Self-host only)
# Any OpenAI-compatible endpoint works (OpenAI, DeepSeek, OpenRouter, etc.)
# Anthropic native API is auto-detected by "anthropic.com" in the URL.
# PROCESSING_LLM_BASE_URL=https://api.openai.com/v1
# PROCESSING_LLM_API_KEY=sk-...
# PROCESSING_LLM_MODEL=gpt-4o-mini

# Proxy service
PROCESSING_URL=http://processing:8081
# ALLOW_PLAINTEXT_INTERNAL=true  # Uncomment for Docker-internal networking only. Do NOT enable in production with external Processing URL.
PROXY_PORT=8080
PROVIDER_TIMEOUT_SECONDS=120

# Billing service (cloud-only — leave empty for self-host).
# When BILLING_URL is set, /api/meta exposes it and the dashboard renders
# the Pro-request UI, fetching status from this URL. When empty, the
# dashboard hides all billing-related UI.
# BILLING_URL=https://billing.agentorbit.tech

# Cookie Domain attribute for the auth cookie (cloud-only — leave empty for self-host).
# When billing lives on a sibling subdomain, set this to the parent domain
# (with leading dot) so the agentorbit_token cookie is shared between
# agentorbit.tech and billing.agentorbit.tech.
# COOKIE_DOMAIN=.agentorbit.tech

# Error tracking (optional — set SENTRY_DSN to enable; leave empty to disable).
# Same DSN is used by proxy, processing, and billing services. See internal-docs/SENTRY.md.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=self-host
# SENTRY_RELEASE=
# SENTRY_SAMPLE_RATE=1.0
